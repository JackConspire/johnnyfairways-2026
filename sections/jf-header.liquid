<script
  src="{{ 'header-drawer.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- liquid
  assign menu_links = section.settings.menu.links
  assign has_menu_links = false

  if menu_links != blank
    assign has_menu_links = true
  endif
-%}

<header class="jf-header" role="banner">
  <header-drawer class="jf-header__drawer">
    <details
      id="Details-jf-menu-drawer-container"
      class="menu-drawer-container jf-mobile-menu-container"
      ref="details"
      scroll-lock
    >
      <summary
        class="jf-header__menu-button"
        aria-label="{{ 'accessibility.menu' | t }}"
        aria-expanded="false"
        on:click="/toggle"
      >
        <span></span>
        <span></span>
        <span></span>
      </summary>

      <div
        ref="menuDrawer"
        class="menu-drawer jf-mobile-menu"
      >
        <div class="jf-mobile-menu__header">
          <p class="jf-label">{{ section.settings.mobile_menu_label }}</p>
          <button
            class="jf-mobile-menu__close"
            type="button"
            aria-label="{{ 'actions.close' | t }}"
            on:click="/close"
          >
            {{ 'icon-close.svg' | inline_asset_content }}
          </button>
        </div>

        <nav class="jf-mobile-menu__nav" aria-label="{{ 'accessibility.header_navigation_label' | t }}">
          {%- if has_menu_links -%}
            {%- for link in menu_links -%}
              {%- if link.links != blank -%}
                <details
                  class="jf-mobile-menu__group menu-drawer__animated-element"
                  style="--menu-drawer-animation-index: {{ forloop.index }};"
                >
                  <summary class="jf-mobile-menu__link jf-mobile-menu__summary">
                    <span>{{ link.title | escape }}</span>
                    <span aria-hidden="true">/ {{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
                  </summary>
                  <div class="jf-mobile-menu__submenu">
                    <a class="jf-mobile-menu__submenu-link" href="{{ link.url }}">View all {{ link.title | escape }}</a>
                    {%- for child_link in link.links -%}
                      <a class="jf-mobile-menu__submenu-link" href="{{ child_link.url }}">{{ child_link.title | escape }}</a>
                      {%- if child_link.links != blank -%}
                        <div class="jf-mobile-menu__grandchild">
                          {%- for grandchild_link in child_link.links -%}
                            <a class="jf-mobile-menu__grandchild-link" href="{{ grandchild_link.url }}">{{ grandchild_link.title | escape }}</a>
                          {%- endfor -%}
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </details>
              {%- else -%}
                <a
                  class="jf-mobile-menu__link menu-drawer__animated-element"
                  href="{{ link.url }}"
                  style="--menu-drawer-animation-index: {{ forloop.index }};"
                >
                  <span>{{ link.title | escape }}</span>
                  <span aria-hidden="true">/ {{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
                </a>
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'nav_link' -%}
                <a
                  class="jf-mobile-menu__link menu-drawer__animated-element"
                  href="{{ block.settings.url | default: routes.root_url }}"
                  style="--menu-drawer-animation-index: {{ forloop.index }};"
                >
                  <span>{{ block.settings.label | escape }}</span>
                  <span aria-hidden="true">/ {{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
                </a>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        </nav>

        <div class="jf-mobile-menu__utilities">
          {%- if section.settings.show_search -%}
            <a href="{{ routes.search_url }}">Search</a>
          {%- endif -%}
          {%- if section.settings.show_account and shop.customer_accounts_enabled -%}
            <a href="{{ routes.account_url }}">Account</a>
          {%- endif -%}
          <a href="{{ routes.cart_url }}">Cart ({{ cart.item_count }})</a>
        </div>
      </div>
    </details>
  </header-drawer>

  <nav class="jf-header__nav" aria-label="Primary">
    <ul class="jf-header__nav-list" role="list">
      {%- if has_menu_links -%}
        {%- for link in menu_links -%}
          <li class="jf-header__nav-item{% if link.links != blank %} jf-header__nav-item--has-dropdown{% endif %}">
            <a class="jf-header__link" href="{{ link.url }}" {% if link.current %}aria-current="page"{% endif %}>
              {{ link.title | escape }}
            </a>
            {%- if link.links != blank -%}
              <div class="jf-header__dropdown" aria-label="{{ link.title | escape }}">
                <ul class="jf-header__dropdown-list" role="list">
                  {%- for child_link in link.links -%}
                    <li class="jf-header__dropdown-item">
                      <a class="jf-header__dropdown-link" href="{{ child_link.url }}" {% if child_link.current %}aria-current="page"{% endif %}>
                        {{ child_link.title | escape }}
                      </a>
                      {%- if child_link.links != blank -%}
                        <ul class="jf-header__dropdown-sublist" role="list">
                          {%- for grandchild_link in child_link.links -%}
                            <li>
                              <a class="jf-header__dropdown-sublink" href="{{ grandchild_link.url }}" {% if grandchild_link.current %}aria-current="page"{% endif %}>
                                {{ grandchild_link.title | escape }}
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'nav_link' -%}
            <li class="jf-header__nav-item" {{ block.shopify_attributes }}>
              <a class="jf-header__link" href="{{ block.settings.url | default: routes.root_url }}">
                {{ block.settings.label | escape }}
              </a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </ul>
  </nav>

  <a
    class="jf-header__brand{% if section.settings.logo_image != blank %} jf-header__brand--image{% endif %}"
    href="{{ routes.root_url }}"
    aria-label="{{ shop.name | escape }}"
    style="--jf-header-logo-width: {{ section.settings.logo_width }}px; --jf-header-logo-width-mobile: {{ section.settings.logo_width_mobile }}px;"
  >
    {%- if section.settings.logo_image != blank -%}
      {{
        section.settings.logo_image
        | image_url: width: 600
        | image_tag:
          class: 'jf-header__brand-image',
          widths: '120, 180, 240, 320, 480, 600',
          sizes: '(max-width: 749px) var(--jf-header-logo-width-mobile), var(--jf-header-logo-width)',
          alt: shop.name,
          loading: 'eager'
      }}
    {%- elsif section.settings.logo_text != blank -%}
      <span class="jf-header__brand-text">{{ section.settings.logo_text | escape }}</span>
    {%- else -%}
      <span class="jf-header__brand-text">{{ shop.name | escape }}</span>
    {%- endif -%}
  </a>

  <div class="jf-header__actions">
    {%- if section.settings.show_search -%}
      <a class="jf-header__link" href="{{ routes.search_url }}">Search</a>
    {%- endif -%}
    {%- if section.settings.show_account and shop.customer_accounts_enabled -%}
      <a class="jf-header__link" href="{{ routes.account_url }}">Account</a>
    {%- endif -%}
    <a class="jf-header__link jf-header__cart" href="{{ routes.cart_url }}">Cart ({{ cart.item_count }})</a>
  </div>
</header>

{% schema %}
{
  "name": "JF header",
  "class": "jf-header-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main menu",
      "default": "main-menu"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 60,
      "max": 320,
      "step": 4,
      "unit": "px",
      "default": 156
    },
    {
      "type": "range",
      "id": "logo_width_mobile",
      "label": "Mobile logo width",
      "min": 48,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 132
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Fallback logo text",
      "default": "JF1"
    },
    {
      "type": "text",
      "id": "mobile_menu_label",
      "label": "Mobile menu label",
      "default": "/ MENU"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Navigation link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "SHOP"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "JF header",
      "blocks": [
        {
          "type": "nav_link",
          "settings": {
            "label": "SHOP"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "label": "LOOKBOOK"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "label": "STORY"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "label": "JOURNAL"
          }
        }
      ]
    }
  ]
}
{% endschema %}
