{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign hero_heading = product.metafields.custom.pdp_hero_heading.value | default: section.settings.heading
  assign hero_copy = product.metafields.custom.pdp_hero_copy.value | default: section.settings.copy
  assign product_image = product.metafields.custom.pdp_hero_image.value

  if section.settings.hero_image != blank
    assign hero_image_url = section.settings.hero_image | image_url: width: 1800
  elsif product_image != blank
    assign hero_image_url = product_image | image_url: width: 1800
  elsif product.featured_media.preview_image != blank
    assign hero_image_url = product.featured_media.preview_image | image_url: width: 1800
  else
    assign hero_image_url = section.settings.fallback_asset | default: 'jf-pdp-cap-hero.png' | asset_url
  endif
-%}

<section class="jf-pdp-hero">
  <div class="jf-pdp-crumb">
    <div class="jf-pdp-crumb__trail">
      <span>Shop</span><span>/</span><span>{{ product.type | default: 'Accessories' }}</span><span>/</span>
      <strong>{{ product.title }}</strong>
    </div>
    <div class="jf-pdp-crumb__nav">
      <span>&larr; Prev</span><span>{{ section.settings.product_position }}</span><span>Next &rarr;</span>
    </div>
  </div>

  <div class="jf-pdp-hero__main" style="--jf-pdp-info-width: {{ section.settings.info_width }}%;">
    <div class="jf-pdp-hero__media">
      <img src="{{ hero_image_url }}" alt="{{ product.title | escape }}" loading="eager" width="1200" height="1200">
      <div class="jf-pdp-barcode" aria-hidden="true">
        <span></span><span class="wide"></span><span></span><span class="fat"></span><span></span><span></span><span class="wide"></span><span></span><span></span><span class="wide"></span><span></span><span class="fat"></span><span></span><span class="wide"></span><span></span><span></span><span class="wide"></span><span class="fat"></span><span></span><span></span><span class="wide"></span><span></span><span></span><span class="wide"></span>
        <small>00 0123456 000004 8</small>
      </div>
      <div class="jf-pdp-hero__caption jf-label">
        <span>/ 004 - Accessories</span>
        <span>Shot no. 01 of 06</span>
      </div>
    </div>

    <div class="jf-pdp-hero__panel">
      <div class="jf-pdp-hero__meta">
        <div><span>Drop no.</span><strong>{{ section.settings.drop_no }}</strong></div>
        <div><span>Release</span><strong>{{ section.settings.release }}</strong></div>
        <div><span>Dropped</span><strong>{{ section.settings.dropped }}</strong></div>
      </div>

      <div class="jf-pdp-hero__copy">
        <p class="jf-label">{{ section.settings.eyebrow }}</p>
        <h1>{{ hero_heading | default: product.title }}</h1>
        <p>{{ hero_copy }}</p>
      </div>

      <div class="jf-pdp-hero__purchase">
        <div class="jf-pdp-hero__price">
          <strong>{{ current_variant.price | money_with_currency }}</strong>
          <span>{% if current_variant.available %}In stock - ships within 24h{% else %}Sold out{% endif %}</span>
        </div>

        <product-form-component
          data-section-id="{{ section.id }}"
          data-product-id="{{ product.id }}"
          data-product-url="{{ product.url }}"
          on:submit="/handleSubmit"
          data-quantity-default="1"
          data-quantity-error-max="{{ 'products.product.quantity_error_max' | t }}"
        >
          <div class="visually-hidden" aria-live="assertive" role="status" aria-atomic="true" ref="liveRegion"></div>
          {%- form 'product', product, id: 'JFPDPHeroForm', data-type: 'add-to-cart-form' -%}
            <input type="hidden" name="id" ref="variantId" value="{{ current_variant.id }}">
            <input type="hidden" name="quantity" value="1">
            <div class="product-form-text__error hidden" ref="addToCartTextError"></div>
            {% render 'add-to-cart-button',
              can_add_to_cart: current_variant.available,
              add_to_cart_text: section.settings.add_to_cart_label,
              product: product,
              class: 'jf-pdp-hero__button',
              id: 'JFPDPHeroAddToCart'
            %}
          {%- endform -%}
        </product-form-component>
      </div>
    </div>
  </div>
</section>

<section class="jf-pdp-spec-strip" aria-label="{{ section.settings.spec_label | escape }}">
  {%- for block in section.blocks -%}
    <div class="jf-pdp-spec-strip__item" {{ block.shopify_attributes }}>
      <span>{{ block.settings.label | escape }}</span>
      <strong>{% render 'jf-metafield-value', product: product, namespace: block.settings.namespace, key: block.settings.key, fallback: block.settings.value %}</strong>
    </div>
  {%- endfor -%}
</section>

{% schema %}
{
  "name": "JF PDP hero",
  "settings": [
    { "type": "text", "id": "product_position", "label": "Product position", "default": "4 / 24" },
    { "type": "text", "id": "drop_no", "label": "Drop number", "default": "/ 004" },
    { "type": "text", "id": "release", "label": "Release", "default": "FW / 21" },
    { "type": "text", "id": "dropped", "label": "Dropped", "default": "JAN 12 / 2:20 PM" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "LIMITED EDITION - ACCESSORIES" },
    { "type": "text", "id": "heading", "label": "Fallback heading", "default": "9 FLAG // CAMO" },
    { "type": "textarea", "id": "copy", "label": "Fallback copy", "default": "A six-panel performance cap for the round and the after-round. Laser-perforated crown, JF wave embroidered at the front, structured brim broken in just enough." },
    { "type": "image_picker", "id": "hero_image", "label": "Fallback hero image" },
    { "type": "text", "id": "fallback_asset", "label": "Fallback asset filename", "default": "jf-pdp-cap-hero.png" },
    {
      "type": "select",
      "id": "info_width",
      "label": "Information box width",
      "info": "Desktop only. The product image uses the remaining width.",
      "options": [
        { "value": "30", "label": "30%" },
        { "value": "35", "label": "35%" },
        { "value": "40", "label": "40%" },
        { "value": "45", "label": "45%" },
        { "value": "50", "label": "50%" }
      ],
      "default": "40"
    },
    { "type": "text", "id": "add_to_cart_label", "label": "Add to cart label", "default": "ADD TO CART" },
    { "type": "text", "id": "spec_label", "label": "Spec strip accessibility label", "default": "Product specifications" }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "Spec",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "STYLE" },
        { "type": "text", "id": "namespace", "label": "Metafield namespace", "default": "custom" },
        { "type": "text", "id": "key", "label": "Metafield key", "default": "pdp_style" },
        { "type": "text", "id": "value", "label": "Fallback value", "default": "5-PANEL" }
      ]
    }
  ],
  "presets": [{ "name": "JF PDP hero" }]
}
{% endschema %}
