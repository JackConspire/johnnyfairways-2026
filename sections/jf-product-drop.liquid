          "label": "Image override"
        },
        {
          "type": "text",
          "id": "fallback_asset",
          "label": "Fallback asset filename",
          "default": "jf-product-01.jpg"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge",
          "default": "NEW"
        },
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "/ 001"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Manual title",
          "default": "THE CADDY POLO"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Manual price",
          "default": "$148"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "PERFORMANCE - 3 COLORS"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Manual link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "JF product drop",
      "blocks": [
        {
          "type": "product_tile",
          "settings": {
            "fallback_asset": "jf-product-01.jpg",
