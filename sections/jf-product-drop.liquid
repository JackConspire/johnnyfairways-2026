<section class="jf-products">
  <div class="jf-section-header">
    <div class="jf-label">{{ section.settings.eyebrow | escape }}</div>
    <h2 class="jf-section-header__title jf-display">{{ section.settings.heading | escape }}</h2>
    {%- if section.settings.link_label != blank -%}
      <a class="jf-section-header__action jf-label" href="{{ section.settings.link | default: routes.all_products_collection_url }}">
        {{ section.settings.link_label | escape }}
      </a>
    {%- endif -%}
  </div>
  <div class="jf-spacer-line" aria-hidden="true"></div>

  <div class="jf-product-grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'product_tile' -%}
        {%- liquid
          assign product = block.settings.product
          assign is_sold_out = false
          assign card_image = blank
          assign card_hover_image = blank
          assign fallback_image_url = ''

          if product != blank and product.available == false
            assign is_sold_out = true
          endif

          if block.settings.image != blank
            assign card_image = block.settings.image
          elsif product.featured_image != blank
            assign card_image = product.featured_image
          elsif block.settings.fallback_asset != blank
            assign fallback_image_url = block.settings.fallback_asset | asset_url
          endif

          if block.settings.hover_image != blank
            assign card_hover_image = block.settings.hover_image
          elsif product != blank
            assign featured_image = product.featured_image
            for product_image in product.images
              unless product_image == featured_image
                assign card_hover_image = product_image
                break
              endunless
            endfor
          endif

          assign title = block.settings.title
          if title == blank and product != blank
            assign title = product.title
          endif

          assign price = block.settings.price
          if price == blank and product != blank
            assign price = product.price | money_without_trailing_zeros
          endif

          assign badge = block.settings.badge
          if is_sold_out
            assign badge = 'Sold out'
          endif

          assign href = block.settings.link
          if href == blank and product != blank
            assign href = product.url
          endif
          if href == blank
            assign href = routes.all_products_collection_url
          endif
        -%}
        <a class="jf-product-card{% if is_sold_out %} jf-product-card--sold-out{% endif %}" href="{{ href }}" {{ block.shopify_attributes }}>
          <div class="jf-product-card__image">
            {%- if card_image != blank -%}
              {{
                card_image
                | image_url: width: 900
                | image_tag:
                  widths: '360, 520, 720, 900',
                  sizes: '(min-width: 990px) 25vw, 50vw',
                  loading: 'lazy',
                  class: 'jf-product-card__img'
              }}
              {%- if card_hover_image != blank -%}
                {{
                  card_hover_image
                  | image_url: width: 900
                  | image_tag:
                    widths: '360, 520, 720, 900',
                    sizes: '(min-width: 990px) 25vw, 50vw',
                    loading: 'lazy',
                    class: 'jf-product-card__img jf-product-card__img--secondary'
                }}
              {%- endif -%}
            {%- elsif fallback_image_url != blank -%}
              <img
                src="{{ fallback_image_url }}"
                alt="{{ title | escape }}"
                class="jf-product-card__img"
                width="900"
                height="1200"
                loading="lazy"
              >
            {%- endif -%}
            {%- if badge != blank -%}
              <span class="jf-product-card__badge">{{ badge | escape }}</span>
            {%- endif -%}
            {%- if is_sold_out -%}
              <span class="jf-product-card__sold-out jf-display">Sold Out</span>
            {%- endif -%}
            {%- if block.settings.number != blank -%}
              <span class="jf-product-card__number">{{ block.settings.number | escape }}</span>
            {%- endif -%}
          </div>
          <div class="jf-product-card__meta">
            <div class="jf-product-card__title jf-display">{{ title | escape }}</div>
            {%- if price != blank -%}
              <div class="jf-product-card__price">{{ price | escape }}</div>
            {%- endif -%}
          </div>
          {%- if block.settings.subtitle != blank -%}
            <div class="jf-product-card__subtitle">{{ block.settings.subtitle | escape }}</div>
          {%- endif -%}
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
