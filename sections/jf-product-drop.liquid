          }
        },
        {
          "type": "product_tile",
          "settings": {
            "fallback_asset": "jf-product-02.jpg",
            "badge": "LIMITED",
            "number": "/ 002",
            "title": "THE 18TH TROUSER",
            "price": "$215",
            "subtitle": "EVERYDAY - 4 COLORS"
          }
        },
        {
          "type": "product_tile",
          "settings": {
            "fallback_asset": "jf-product-03.jpg",
            "badge": "NEW",
            "number": "/ 003",
            "title": "THE TEE TIME 1/4",
            "price": "$185",
            "subtitle": "PERFORMANCE - 2 COLORS"
          }
        },
        {
          "type": "product_tile",
          "settings": {
            "fallback_asset": "jf-product-04.jpg",
            "badge": "FW / 21",
            "number": "/ 004",
            "title": "THE FAIRWAY CAP",
            "price": "$58",
            "subtitle": "ACCESSORIES - 5 COLORS"
