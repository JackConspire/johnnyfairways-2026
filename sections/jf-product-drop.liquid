<section class="jf-products">
  <div class="jf-section-header">
    <div class="jf-label">{{ section.settings.eyebrow | escape }}</div>
    <h2 class="jf-section-header__title jf-display">{{ section.settings.heading | escape }}</h2>
    {%- if section.settings.link_label != blank -%}
      <a class="jf-section-header__action jf-label" href="{{ section.settings.link | default: routes.all_products_collection_url }}">
        {{ section.settings.link_label | escape }}
      </a>
    {%- endif -%}
  </div>
  <div class="jf-spacer-line" aria-hidden="true"></div>

  <div class="jf-product-grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'product_tile' -%}
        {%- liquid
          assign product = block.settings.product
          assign image_url = ''
          if block.settings.image != blank
            assign image_url = block.settings.image | image_url: width: 900
          elsif product.featured_image != blank
            assign image_url = product.featured_image | image_url: width: 900
          elsif block.settings.fallback_asset != blank
            assign image_url = block.settings.fallback_asset | asset_url
          endif

          assign title = block.settings.title
          if title == blank and product != blank
            assign title = product.title
          endif

          assign price = block.settings.price
          if price == blank and product != blank
            assign price = product.price | money_without_trailing_zeros
          endif

          assign href = block.settings.link
          if href == blank and product != blank
            assign href = product.url
          endif
          if href == blank
            assign href = routes.all_products_collection_url
          endif
        -%}
        <a class="jf-product-card" href="{{ href }}" {{ block.shopify_attributes }}>
          <div class="jf-product-card__image jf-image-cover" style="{% if image_url != blank %}--jf-image: url('{{ image_url }}');{% endif %}">
            {%- if block.settings.badge != blank -%}
              <span class="jf-product-card__badge">{{ block.settings.badge | escape }}</span>
            {%- endif -%}
            {%- if block.settings.number != blank -%}
              <span class="jf-product-card__number">{{ block.settings.number | escape }}</span>
            {%- endif -%}
          </div>
          <div class="jf-product-card__meta">
            <div class="jf-product-card__title jf-display">{{ title | escape }}</div>
            {%- if price != blank -%}
              <div class="jf-product-card__price">{{ price | escape }}</div>
            {%- endif -%}
          </div>
          {%- if block.settings.subtitle != blank -%}
            <div class="jf-product-card__subtitle">{{ block.settings.subtitle | escape }}</div>
          {%- endif -%}
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "JF product drop",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "/ 01 - THE DROP"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FEATURED"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "VIEW ALL 24 ->"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "blocks": [
    {
      "type": "product_tile",
      "name": "Product tile",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
