<section class="jf-lookbook">
  <div class="jf-section-header">
    <div class="jf-label">{{ section.settings.eyebrow | escape }}</div>
    <h2 class="jf-section-header__title jf-display">{{ section.settings.heading | escape }}</h2>
    {%- if section.settings.link_label != blank -%}
      <a class="jf-section-header__action jf-label" href="{{ section.settings.link | default: routes.root_url }}">
        {{ section.settings.link_label | escape }}
      </a>
    {%- endif -%}
  </div>
  <div class="jf-spacer-line" aria-hidden="true"></div>

  <div class="jf-lookbook__strip">
    {%- for block in section.blocks -%}
      {%- liquid
        if block.settings.image != blank
          assign image_url = block.settings.image | image_url: width: 900
        elsif block.settings.fallback_asset != blank
          assign image_url = block.settings.fallback_asset | asset_url
        else
          assign image_url = ''
        endif
      -%}
      <figure class="jf-lookbook-card" {{ block.shopify_attributes }}>
        <div class="jf-lookbook-card__image jf-image-cover" style="{% if image_url != blank %}--jf-image: url('{{ image_url }}');{% endif %}"></div>
        <figcaption class="jf-lookbook-card__meta">
          <span>{{ block.settings.label | escape }}</span>
          <span>{{ block.settings.season | escape }}</span>
        </figcaption>
      </figure>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "JF lookbook strip",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "/ 04 - LOOKBOOK"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SS '26"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "SEE FULL LOOKBOOK ->"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "blocks": [
    {
      "type": "frame",
      "name": "Frame",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "fallback_asset",
          "label": "Fallback asset filename",
          "default": "jf-lookbook-01.jpg"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "FRAME / 01"
        },
        {
          "type": "text",
          "id": "season",
          "label": "Season",
          "default": "FW / 21"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "JF lookbook strip",
      "blocks": [
        {
          "type": "frame",
          "settings": {
            "fallback_asset": "jf-lookbook-01.jpg",
            "label": "FRAME / 01"
          }
        },
        {
          "type": "frame",
          "settings": {
            "fallback_asset": "jf-lookbook-02.jpg",
            "label": "FRAME / 02"
          }
        },
        {
          "type": "frame",
          "settings": {
            "fallback_asset": "jf-lookbook-03.jpg",
            "label": "FRAME / 03"
          }
        },
        {
          "type": "frame",
          "settings": {
            "fallback_asset": "jf-lookbook-04.jpg",
            "label": "FRAME / 04"
          }
        },
        {
          "type": "frame",
          "settings": {
            "fallback_asset": "jf-lookbook-05.jpg",
            "label": "FRAME / 05"
          }
        },
        {
          "type": "frame",
          "settings": {
            "fallback_asset": "jf-lookbook-06.jpg",
            "label": "FRAME / 06"
          }
        }
      ]
    }
  ]
}
{% endschema %}
