{%- liquid
  assign page_title = section.settings.heading
  if page_title == blank
    assign page_title = collection.title
  endif

  assign page_copy = section.settings.copy
  if page_copy == blank
    assign page_copy = collection.description
  endif

  assign product_total = collection.products_count
  assign result_label = product_total | append: ' results'
  assign piece_label = product_total | append: ' pieces — inspired by golf'
-%}

<section class="jf-collection jf-surface">
  <div class="jf-collection-breadcrumb">
    <div class="jf-collection-breadcrumb__trail">
      <span>Shop</span>
      <span>/</span>
      <strong>{{ section.settings.breadcrumb_label | escape }}</strong>
    </div>
    {%- if section.settings.back_label != blank -%}
      <a href="{{ section.settings.back_link | default: routes.all_products_collection_url }}">
        {{ section.settings.back_label | escape }}
      </a>
    {%- endif -%}
  </div>

  <header class="jf-collection-page-header jf-dark">
    <div class="jf-collection-page-header__top">
      <div class="jf-label">{{ section.settings.eyebrow | escape }}</div>
      <div class="jf-collection-page-header__drops">
        <span>{{ section.settings.release_label | escape }}</span>
        <span>{{ section.settings.dropped_label | escape }}</span>
      </div>
    </div>
    <div class="jf-collection-page-header__body">
      <h1 class="jf-collection-page-header__title jf-display">{{ page_title | escape }}</h1>
      <div class="jf-collection-page-header__copy">
        <div class="jf-label">{{ piece_label }}</div>
        {%- if page_copy != blank -%}
          <div class="jf-collection-page-header__text">{{ page_copy }}</div>
        {%- endif -%}
      </div>
    </div>
  </header>

  <div class="jf-collection-filter-bar">
    <div class="jf-collection-filter-bar__group" aria-label="Collection filters">
      <button type="button" class="jf-filter-pill jf-filter-pill--outline">All filters</button>
      <span class="jf-collection-filter-bar__divider" aria-hidden="true"></span>
      <button type="button" class="jf-filter-pill jf-filter-pill--active">Category</button>
      <button type="button" class="jf-filter-pill jf-filter-pill--outline">Size</button>
      <button type="button" class="jf-filter-pill jf-filter-pill--outline">Color</button>
      <button type="button" class="jf-filter-pill jf-filter-pill--outline">Price</button>
      <button type="button" class="jf-filter-pill jf-filter-pill--outline">Fit</button>
    </div>
    <div class="jf-collection-filter-bar__sort">
      <span>{{ result_label }}</span>
      <form method="get" class="jf-collection-sort">
        <label for="SortBy-{{ section.id }}">Sort:</label>
        <select id="SortBy-{{ section.id }}" name="sort_by" onchange="this.form.submit()">
          {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
          {%- for option in collection.sort_options -%}
            <option value="{{ option.value | escape }}"{% if option.value == sort_by %} selected{% endif %}>
              {{ option.name | escape }}
            </option>
          {%- endfor -%}
        </select>
      </form>
    </div>
  </div>

  {%- assign active_filters_count = 0 -%}
  {%- capture active_filter_chips -%}
    {%- for filter in collection.filters -%}
      {%- for value in filter.active_values -%}
        {%- assign active_filters_count = active_filters_count | plus: 1 -%}
        <a class="jf-active-filter" href="{{ value.url_to_remove }}">
          {{ filter.label | escape }}: {{ value.label | escape }} <span aria-hidden="true">×</span>
        </a>
      {%- endfor -%}
      {%- if filter.type == 'price_range' -%}
        {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
          {%- assign active_filters_count = active_filters_count | plus: 1 -%}
          <a class="jf-active-filter" href="{{ filter.url_to_remove }}">
            {{ filter.label | escape }} <span aria-hidden="true">×</span>
          </a>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endcapture -%}

  <div class="jf-collection-active-filters">
    <div class="jf-collection-active-filters__chips">
      <span>Active:</span>
      {%- if active_filters_count > 0 -%}
        {{ active_filter_chips }}
      {%- else -%}
        {%- assign default_chips = section.settings.default_filter_chips | split: ',' -%}
        {%- for chip in default_chips -%}
          {%- assign chip_label = chip | strip -%}
          {%- if chip_label != blank -%}
            <span class="jf-active-filter">{{ chip_label | escape }} <span aria-hidden="true">×</span></span>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
    <a href="{{ collection.url }}">Clear all -&gt;</a>
  </div>

  {%- paginate collection.products by section.settings.products_per_page -%}
    <div class="jf-collection-grid-section">
      {%- if collection.products.size > 0 -%}
        <ul class="jf-collection-grid" role="list">
          {%- for product in collection.products -%}
            {%- liquid
              assign card_image = product.featured_image
              assign card_price = product.price | money_without_trailing_zeros
              assign card_subtitle = product.type
              if card_subtitle == blank
                assign card_subtitle = product.vendor
              endif

              assign card_badge = ''
              unless product.available
                assign card_badge = 'Sold out'
              endunless
              if card_badge == blank
                for tag in product.tags
                  assign downcase_tag = tag | downcase
                  if downcase_tag == 'new' or downcase_tag == 'limited' or downcase_tag == 'fw / 21' or downcase_tag == 'fw21'
                    assign card_badge = tag
                    break
                  endif
                endfor
              endif
            -%}
            <li class="jf-collection-grid__item">
              <a class="jf-collection-card{% unless product.available %} jf-collection-card--sold-out{% endunless %}" href="{{ product.url | within: collection }}">
                <div class="jf-collection-card__image">
                  {%- if card_image != blank -%}
                    {{
                      card_image
                      | image_url: width: 900
                      | image_tag:
                        widths: '360, 520, 720, 900',
                        sizes: '(min-width: 990px) 25vw, 50vw',
                        loading: 'lazy',
                        class: 'jf-collection-card__img'
                    }}
                  {%- else -%}
                    {{ 'product-apparel-1' | placeholder_svg_tag: 'jf-collection-card__placeholder' }}
                  {%- endif -%}
                  {%- if card_badge != blank -%}
                    <span class="jf-collection-card__badge">{{ card_badge | escape }}</span>
                  {%- endif -%}
                  {%- unless product.available -%}
                    <span class="jf-collection-card__sold-out jf-display">Sold Out</span>
                  {%- endunless -%}
                  <span class="jf-collection-card__number">/ {{ forloop.index | prepend: '00' | slice: -3, 3 }}</span>
                </div>
                <div class="jf-collection-card__meta">
                  <h2 class="jf-collection-card__title jf-display">{{ product.title | escape }}</h2>
                  <div class="jf-collection-card__price">{{ card_price }}</div>
                </div>
                {%- if card_subtitle != blank -%}
                  <div class="jf-collection-card__subtitle">{{ card_subtitle | escape }} · / {{ forloop.index | prepend: '00' | slice: -3, 3 }}</div>
                {%- endif -%}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <div class="jf-collection-empty">
          <h2 class="jf-display">No Products Found</h2>
          <p>There are no products in this collection yet.</p>
        </div>
      {%- endif -%}

      <div class="jf-collection-end">
        <span>Showing {{ collection.products.size }} of {{ product_total }} pieces</span>
        <div aria-hidden="true"></div>
        <a href="{{ section.settings.end_link | default: routes.all_products_collection_url }}">
          {{ section.settings.end_label | escape }}
        </a>
      </div>

      {%- if paginate.pages > 1 -%}
        <div class="jf-collection-pagination">
          {%- if paginate.previous -%}
            <a class="jf-btn jf-btn--ghost" href="{{ paginate.previous.url }}"><span class="jf-btn__text">Previous</span></a>
          {%- endif -%}
          {%- if paginate.next -%}
            <a class="jf-btn jf-btn--dark" href="{{ paginate.next.url }}">View More</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  {%- endpaginate -%}
</section>

{% schema %}
{
  "name": "JF collection template",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "breadcrumb_label",
      "label": "Breadcrumb label",
      "default": "Shop all — FW '21 drop"
    },
    {
      "type": "text",
      "id": "back_label",
      "label": "Back label",
      "default": "Back to shop"
    },
    {
      "type": "url",
      "id": "back_link",
      "label": "Back link"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "/ Collection 001 — The Drop"
    },
    {
      "type": "text",
      "id": "release_label",
      "label": "Release label",
      "default": "Release — FW / 21"
    },
    {
      "type": "text",
      "id": "dropped_label",
      "label": "Dropped label",
      "default": "Dropped — Jan 12 / 2:20 PM"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop all."
    },
    {
      "type": "richtext",
      "id": "copy",
      "label": "Copy",
      "default": "<p>Performance and everyday pieces, drawn from the rhythm of the round. Limited release. Hand-finished in Porto. Free shipping over $150.</p>"
    },
    {
      "type": "header",
      "content": "Filters"
    },
    {
      "type": "text",
      "id": "default_filter_chips",
      "label": "Default filter chips",
      "default": "Category: Performance, Category: Everyday, Price: Under $200"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "text",
      "id": "end_label",
      "label": "End label",
      "default": "End of collection — browse other drops ->"
    },
    {
      "type": "url",
      "id": "end_link",
      "label": "End link"
    }
  ],
  "presets": [
    {
      "name": "JF collection template"
    }
  ]
}
{% endschema %}
