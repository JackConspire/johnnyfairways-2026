{%- liquid
  assign hero_image = section.settings.hero_image
  if hero_image == blank
    assign hero_image = collection.image
  endif
  if hero_image == blank and collection.products.first.featured_image != blank
    assign hero_image = collection.products.first.featured_image
  endif

  assign hero_title = section.settings.hero_title
  if hero_title == blank
    assign hero_title = collection.title
  endif

  assign hero_text = section.settings.hero_text
  if hero_text == blank
    assign hero_text = collection.description
  endif

  assign grid_title = section.settings.grid_title
  if grid_title == blank
    assign grid_title = collection.title
  endif

  assign product_count_label = section.settings.product_count_label
  if product_count_label == blank
    assign product_count_label = collection.products_count | append: ' styles'
  endif
-%}

<section class="jf-collection jf-surface">
  <div class="jf-collection-hero jf-dark">
    {%- if hero_image != blank -%}
      <div class="jf-collection-hero__media">
        {{
          hero_image
          | image_url: width: 2200
          | image_tag:
            widths: '750, 1100, 1440, 1800, 2200',
            sizes: '100vw',
            loading: 'eager',
            class: 'jf-collection-hero__image'
        }}
      </div>
    {%- endif -%}
    <div class="jf-collection-hero__overlay" aria-hidden="true"></div>
    <div class="jf-collection-hero__content">
      {%- if section.settings.hero_eyebrow != blank -%}
        <div class="jf-collection-hero__eyebrow jf-label">{{ section.settings.hero_eyebrow | escape }}</div>
      {%- endif -%}
      <h1 class="jf-collection-hero__title jf-display">{{ hero_title | escape }}</h1>
      {%- if hero_text != blank -%}
        <div class="jf-collection-hero__text">{{ hero_text }}</div>
      {%- endif -%}
      {%- if section.settings.hero_button_label != blank -%}
        <a class="jf-btn jf-btn--light" href="{{ section.settings.hero_button_link | default: collection.url }}">
          {{ section.settings.hero_button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>

  <div class="jf-collection-grid-section">
    <div class="jf-collection-grid-header">
      <div class="jf-label">{{ section.settings.grid_eyebrow | escape }}</div>
      <h2 class="jf-collection-grid-header__title jf-display">{{ grid_title | escape }}</h2>
      <div class="jf-label jf-collection-grid-header__count">{{ product_count_label | escape }}</div>
    </div>

    {%- paginate collection.products by section.settings.products_per_page -%}
      {%- if collection.products.size > 0 -%}
        <ul class="jf-collection-grid" role="list">
          {%- for product in collection.products -%}
            {%- liquid
              assign card_image = product.featured_image
              assign card_price = product.price | money_without_trailing_zeros
              assign card_subtitle = product.type
              if card_subtitle == blank
                assign card_subtitle = product.vendor
              endif
            -%}
            <li class="jf-collection-grid__item">
              <a class="jf-collection-card" href="{{ product.url | within: collection }}">
                <div class="jf-collection-card__image">
                  {%- if card_image != blank -%}
                    {{
                      card_image
                      | image_url: width: 1100
                      | image_tag:
                        widths: '360, 520, 720, 900, 1100',
                        sizes: '(min-width: 990px) 31vw, 50vw',
                        loading: 'lazy',
                        class: 'jf-collection-card__img'
                    }}
                  {%- else -%}
                    {{ 'product-apparel-1' | placeholder_svg_tag: 'jf-collection-card__placeholder' }}
                  {%- endif -%}
                  {%- unless product.available -%}
                    <span class="jf-collection-card__badge">Sold Out</span>
                  {%- endunless -%}
                  <span class="jf-collection-card__number">/ {{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
                </div>
                <div class="jf-collection-card__meta">
                  <h3 class="jf-collection-card__title jf-display">{{ product.title | escape }}</h3>
                  <div class="jf-collection-card__price">{{ card_price }}</div>
                </div>
                {%- if card_subtitle != blank -%}
                  <div class="jf-collection-card__subtitle">{{ card_subtitle | escape }}</div>
                {%- endif -%}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <div class="jf-collection-empty">
          <h2 class="jf-display">No Products Found</h2>
          <p>There are no products in this collection yet.</p>
        </div>
      {%- endif -%}

      {%- if paginate.pages > 1 -%}
        <div class="jf-collection-pagination">
          {%- if paginate.previous -%}
            <a class="jf-btn jf-btn--ghost" href="{{ paginate.previous.url }}"><span class="jf-btn__text">Previous</span></a>
          {%- endif -%}
          {%- if paginate.next -%}
            <a class="jf-btn jf-btn--dark" href="{{ paginate.next.url }}">View More</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>

  {%- if section.settings.show_newsletter -%}
    <div class="jf-collection-newsletter jf-dark">
      <div class="jf-label">{{ section.settings.newsletter_eyebrow | escape }}</div>
      <h2 class="jf-collection-newsletter__title jf-display">{{ section.settings.newsletter_heading | escape }}</h2>
      <div class="jf-collection-newsletter__body">{{ section.settings.newsletter_text }}</div>
      {%- form 'customer', class: 'jf-collection-newsletter__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input
          class="jf-collection-newsletter__input"
          type="email"
          name="contact[email]"
          value="{{ form.email }}"
          aria-label="{{ section.settings.newsletter_placeholder | escape }}"
          placeholder="{{ section.settings.newsletter_placeholder | escape }}"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          required
        >
        <button class="jf-collection-newsletter__submit" type="submit">
          {{ section.settings.newsletter_button_label | escape }} <span aria-hidden="true">-&gt;</span>
        </button>
      {%- endform -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "JF collection template",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Hero eyebrow",
      "default": "Quick dry · perforated hats · new arrival"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title override"
    },
    {
      "type": "richtext",
      "id": "hero_text",
      "label": "Hero text override"
    },
    {
      "type": "text",
      "id": "hero_button_label",
      "label": "Hero button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "hero_button_link",
      "label": "Hero button link"
    },
    {
      "type": "header",
      "content": "Product grid"
    },
    {
      "type": "text",
      "id": "grid_eyebrow",
      "label": "Grid eyebrow",
      "default": "/ 01 — Collection"
    },
    {
      "type": "text",
      "id": "grid_title",
      "label": "Grid title override"
    },
    {
      "type": "text",
      "id": "product_count_label",
      "label": "Product count label override"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 6,
      "max": 48,
      "step": 3,
      "default": 24
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_eyebrow",
      "label": "Newsletter eyebrow",
      "default": "For the [ glory ]"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Join the tee time list."
    },
    {
      "type": "richtext",
      "id": "newsletter_text",
      "label": "Newsletter text",
      "default": "<p>Drop announcements, early access to limited editions, and the occasional dispatch from the back nine.</p>"
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Newsletter placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "newsletter_button_label",
      "label": "Newsletter button label",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "JF collection template"
    }
  ]
}
{% endschema %}
