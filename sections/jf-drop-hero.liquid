{%- liquid
  assign hero_image = section.settings.image
  if hero_image != blank
    assign hero_image_url = hero_image | image_url: width: 1600
  else
    assign hero_image_url = 'jf-hero-model.jpg' | asset_url
  endif
-%}

<section class="jf-hero jf-hero--{{ section.settings.height }}" aria-label="{{ section.settings.heading | escape }}">
  <div class="jf-hero__image jf-image-cover" style="--jf-image: url('{{ hero_image_url }}');"></div>

  <div class="jf-hero__content">
    <div class="jf-barcode" aria-hidden="true">
      <div class="jf-barcode__bars"></div>
      <div>{{ section.settings.barcode_text | escape }}</div>
    </div>

    <div class="jf-hero__meta">
      {%- for block in section.blocks -%}
        {%- if block.type == 'meta' -%}
          <div {{ block.shopify_attributes }}>
            <span class="jf-hero__meta-label">{{ block.settings.label | escape }}</span>
            <span class="jf-hero__meta-value">{{ block.settings.value | escape }}</span>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div>
      {%- if section.settings.kicker != blank -%}
        <div class="jf-hero__kicker jf-display">{{ section.settings.kicker | escape }}</div>
      {%- endif -%}
      <h1 class="jf-hero__title jf-display">{{ section.settings.heading | escape }}</h1>
      {%- if section.settings.text != blank -%}
        <div class="jf-hero__body">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="jf-hero__ctas">
      {%- if section.settings.primary_label != blank -%}
        <a class="jf-btn jf-btn--light" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">
          <span>{{ section.settings.primary_label | escape }}</span><span class="jf-arrow" aria-hidden="true">-&gt;</span>
        </a>
      {%- endif -%}
      {%- if section.settings.secondary_label != blank -%}
        <a class="jf-btn jf-btn--ghost" href="{{ section.settings.secondary_link | default: routes.root_url }}">
          <span class="jf-btn__text">{{ section.settings.secondary_label | escape }}</span>
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "JF drop hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Vertical height",
      "options": [
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        },
        {
          "value": "fit-screen",
          "label": "Fit to screen"
        }
      ],
      "default": "large"
    },
    {
      "type": "text",
      "id": "barcode_text",
      "label": "Barcode text",
      "default": "00 0123456 000001 8"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "NEW RELEASE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BLADE COLLAR"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "FROM PERFORMANCE GOLF APPAREL PERFECT FOR ANY SEASON - TO EVERY DAY ATTIRE THAT'S FIT FOR ANY OCCASION."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary label",
      "default": "SHOP THE DROP"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary label",
      "default": "READ THE STORY"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link"
    }
  ],
  "blocks": [
    {
      "type": "meta",
      "name": "Metadata item",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "RELEASE"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "SS / 26"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "JF drop hero",
      "blocks": [
        {
          "type": "meta",
          "settings": {
            "label": "RELEASE",
            "value": "SS / 26"
          }
        },
        {
          "type": "meta",
          "settings": {
            "label": "DROP NO.",
            "value": "/ 001"
          }
        },
        {
          "type": "meta",
          "settings": {
            "label": "DROPPED",
            "value": "JAN 12 / 2:20 PM"
          }
        }
      ]
    }
  ]
}
{% endschema %}
