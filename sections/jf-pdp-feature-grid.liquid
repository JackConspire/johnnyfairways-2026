<section class="jf-pdp-feature-grid jf-pdp-feature-grid--{{ section.settings.theme }}">
  <div class="jf-pdp-section-head">
    <p class="jf-label">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.heading }}</h2>
    <p class="jf-label">{{ section.settings.kicker }}</p>
  </div>
  <div class="jf-pdp-feature-grid__items">
    {%- for block in section.blocks -%}
      {%- liquid
        assign field_image = product.metafields[block.settings.namespace][block.settings.key].value
        if block.settings.image != blank
          assign image_url = block.settings.image | image_url: width: 900
        elsif field_image != blank
          assign image_url = field_image | image_url: width: 900
        elsif block.settings.fallback_asset != blank
          assign image_url = block.settings.fallback_asset | asset_url
        else
          assign image_url = ''
        endif
      -%}
      <article class="jf-pdp-feature" {{ block.shopify_attributes }}>
        <div class="jf-pdp-feature__image"{% if image_url != blank %} style="--jf-image: url('{{ image_url }}');"{% endif %}></div>
        <div class="jf-pdp-feature__meta">
          <h3>{{ block.settings.title }}</h3>
          <span>{{ block.settings.index }}</span>
        </div>
        <p>{% render 'jf-metafield-value', product: product, namespace: block.settings.text_namespace, key: block.settings.text_key, fallback: block.settings.copy %}</p>
      </article>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "JF PDP feature grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "/ 02 - CRAFT" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "CRAFTSMANSHIP, GRAM BY GRAM." },
    { "type": "text", "id": "kicker", "label": "Right label", "default": "06 TECHNICAL NOTES" },
    {
      "type": "select",
      "id": "theme",
      "label": "Theme",
      "options": [
        { "value": "paper", "label": "Paper" },
        { "value": "black", "label": "Black" }
      ],
      "default": "paper"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "RECYCLED NYLON" },
        { "type": "text", "id": "index", "label": "Index", "default": "/ 01" },
        { "type": "textarea", "id": "copy", "label": "Fallback copy", "default": "Lightweight, water-resistant, and ready for all eighteen." },
        { "type": "image_picker", "id": "image", "label": "Fallback image" },
        { "type": "text", "id": "fallback_asset", "label": "Fallback asset filename" },
        { "type": "text", "id": "namespace", "label": "Image metafield namespace", "default": "custom" },
        { "type": "text", "id": "key", "label": "Image metafield key", "default": "pdp_feature_image_1" },
        { "type": "text", "id": "text_namespace", "label": "Copy metafield namespace", "default": "custom" },
        { "type": "text", "id": "text_key", "label": "Copy metafield key", "default": "pdp_feature_copy_1" }
      ]
    }
  ],
  "presets": [{ "name": "JF PDP feature grid" }]
}
{% endschema %}
