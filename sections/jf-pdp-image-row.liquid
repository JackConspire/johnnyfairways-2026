{%- liquid
  assign metaobject_namespace = section.settings.metaobject_namespace | default: 'custom'
  assign metaobject_key = section.settings.metaobject_key | default: 'pdp_lifestyle'
  assign row_metaobject = product.metafields[metaobject_namespace][metaobject_key].value

  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign kicker = section.settings.kicker
  assign theme = section.settings.theme
  assign image_items = blank

  if row_metaobject != blank
    assign eyebrow = row_metaobject.eyebrow.value | default: eyebrow
    assign heading = row_metaobject.heading.value | default: heading
    assign kicker = row_metaobject.kicker.value | default: kicker
    assign theme = row_metaobject.theme.value | default: theme
    assign image_items = row_metaobject.images.value
  endif
-%}

<section class="jf-pdp-image-row jf-pdp-image-row--{{ theme }}">
  <div class="jf-pdp-section-head">
    <p class="jf-label">{{ eyebrow }}</p>
    <h2>{{ heading }}</h2>
    <p class="jf-label">{{ kicker }}</p>
  </div>
  <div class="jf-pdp-image-row__grid">
    {%- if image_items != blank -%}
      {%- for image_item in image_items -%}
        {%- liquid
          assign item_image = image_item.image.value
          assign image_url = ''

          if item_image != blank
            assign image_url = item_image | image_url: width: 900
          endif
        -%}
        <figure class="jf-pdp-image-row__item">
          <div class="jf-pdp-image-row__image"{% if image_url != blank %} style="--jf-image: url('{{ image_url }}');"{% endif %}></div>
          <figcaption class="jf-label">
            <span>{{ image_item.caption.value | default: image_item.caption }}</span>
            <span>{{ image_item.meta.value | default: image_item.meta }}</span>
          </figcaption>
        </figure>
      {%- endfor -%}
    {%- else -%}
      {%- for block in section.blocks -%}
      {%- liquid
        assign field_image = product.metafields[block.settings.namespace][block.settings.key].value
        if block.settings.image != blank
          assign image_url = block.settings.image | image_url: width: 900
        elsif field_image != blank
          assign image_url = field_image | image_url: width: 900
        elsif block.settings.fallback_asset != blank
          assign image_url = block.settings.fallback_asset | asset_url
        else
          assign image_url = ''
        endif
      -%}
      <figure class="jf-pdp-image-row__item" {{ block.shopify_attributes }}>
        <div class="jf-pdp-image-row__image"{% if image_url != blank %} style="--jf-image: url('{{ image_url }}');"{% endif %}></div>
        <figcaption class="jf-label"><span>{{ block.settings.caption }}</span><span>{{ block.settings.meta }}</span></figcaption>
      </figure>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "JF PDP image row",
  "settings": [
    {
      "type": "paragraph",
      "content": "Optionally reads a product metafield that references a PDP Image Row metaobject. Use custom.pdp_closeups for The Closeups and custom.pdp_lifestyle for In The Wild. The metaobject can include eyebrow, heading, kicker, theme, and a list of PDP Image Item entries."
    },
    { "type": "text", "id": "metaobject_namespace", "label": "Product metafield namespace", "default": "custom" },
    { "type": "text", "id": "metaobject_key", "label": "Product metafield key", "default": "pdp_lifestyle" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "/ 06 - ON THE COURSE" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "IN THE WILD." },
    { "type": "text", "id": "kicker", "label": "Right label", "default": "#JOHNNYFAIRWAYS" },
    {
      "type": "select",
      "id": "theme",
      "label": "Theme",
      "options": [
        { "value": "paper", "label": "Paper" },
        { "value": "black", "label": "Black" }
      ],
      "default": "paper"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "text", "id": "caption", "label": "Caption", "default": "SHOT / 01" },
        { "type": "text", "id": "meta", "label": "Meta", "default": "@JF_FW21" },
        { "type": "image_picker", "id": "image", "label": "Fallback image" },
        { "type": "text", "id": "fallback_asset", "label": "Fallback asset filename" },
        { "type": "text", "id": "namespace", "label": "Image metafield namespace", "default": "custom" },
        { "type": "text", "id": "key", "label": "Image metafield key", "default": "pdp_lifestyle_image_1" }
      ]
    }
  ],
  "presets": [{ "name": "JF PDP image row" }]
}
{% endschema %}
