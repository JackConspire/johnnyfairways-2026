<section class="jf-pdp-complete-look">
  <div class="jf-pdp-section-head">
    <p class="jf-label">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.heading }}</h2>
    <a class="jf-label" href="{{ section.settings.link_url }}">{{ section.settings.link_label }}</a>
  </div>
  <div class="jf-pdp-look-grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign item = block.settings.product
        assign title = block.settings.title
        assign price = block.settings.price
        if item != blank
          assign title = item.title
          assign price = item.price | money_without_trailing_zeros
        endif
        if block.settings.image != blank
          assign image_url = block.settings.image | image_url: width: 900
        elsif item.featured_media.preview_image != blank
          assign image_url = item.featured_media.preview_image | image_url: width: 900
        elsif block.settings.fallback_asset != blank
          assign image_url = block.settings.fallback_asset | asset_url
        else
          assign image_url = ''
        endif
      -%}
      <a class="jf-pdp-look-card" href="{% if item != blank %}{{ item.url }}{% else %}{{ block.settings.url }}{% endif %}" {{ block.shopify_attributes }}>
        <span class="jf-pdp-look-card__image"{% if image_url != blank %} style="--jf-image: url('{{ image_url }}');"{% endif %}></span>
        <span class="jf-pdp-look-card__meta"><strong>{{ title }}</strong><span>{{ price }}</span></span>
        <span class="jf-label">{{ block.settings.subtitle }}</span>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "JF PDP complete look",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "/ 07 - STYLE WITH" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "COMPLETE THE LOOK." },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "VIEW THE EDIT ->" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "title", "label": "Fallback title", "default": "THE CADDY POLO" },
        { "type": "text", "id": "price", "label": "Fallback price", "default": "$148" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "PERFORMANCE - / 001" },
        { "type": "image_picker", "id": "image", "label": "Fallback image" },
        { "type": "text", "id": "fallback_asset", "label": "Fallback asset filename", "default": "jf-product-01.jpg" },
        { "type": "url", "id": "url", "label": "Fallback URL" }
      ]
    }
  ],
  "presets": [{ "name": "JF PDP complete look" }]
}
{% endschema %}
