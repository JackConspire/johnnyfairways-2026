<script
  src="{{ 'product-recommendations.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- liquid
  assign recommendation_product = section.settings.product | default: product
  assign recommendation_product_id = recommendation_product.id | default: product.id
  assign max_products = section.settings.max_products
  assign recommended_products = recommendations.products
  assign has_recommendations = 'false'

  if recommendations.performed and recommended_products.size > 0
    assign has_recommendations = 'true'
  endif
-%}

<product-recommendations
  id="product-recommendations-{{ section.id }}"
  class="product-recommendations jf-pdp-complete-look"
  data-url="{{ routes.product_recommendations_url }}?limit={{ max_products }}"
  data-section-id="{{ section.id }}"
  data-product-id="{{ recommendation_product_id }}"
  data-intent="{{ section.settings.recommendation_type }}"
  data-recommendations-performed="{{ recommendations.performed }}"
  data-hydration-key="product-recommendations-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="jf-pdp-section-head">
    <p class="jf-label">{{ section.settings.eyebrow | escape }}</p>
    <h2>{{ section.settings.heading | escape }}</h2>
    {%- if section.settings.link_label != blank -%}
      <a class="jf-label" href="{{ section.settings.link_url | default: routes.all_products_collection_url }}">
        {{ section.settings.link_label | escape }}
      </a>
    {%- endif -%}
  </div>

  {%- if recommendations.performed -%}
    <div class="jf-pdp-look-grid" data-has-recommendations="{{ has_recommendations }}">
      {%- for item in recommended_products limit: max_products -%}
        {%- liquid
          assign image_url = ''
          assign subtitle = item.type
          assign item_number = forloop.index | prepend: '00' | slice: -3, 3

          if subtitle == blank
            assign subtitle = item.vendor
          endif

          if item.featured_media.preview_image != blank
            assign image_url = item.featured_media.preview_image | image_url: width: 900
          elsif item.featured_image != blank
            assign image_url = item.featured_image | image_url: width: 900
          endif
        -%}
        <a class="jf-pdp-look-card" href="{{ item.url }}">
          <span class="jf-pdp-look-card__image"{% if image_url != blank %} style="--jf-image: url('{{ image_url }}');"{% endif %}></span>
          <span class="jf-pdp-look-card__meta">
            <strong>{{ item.title | escape }}</strong>
            <span>{{ item.price | money_without_trailing_zeros }}</span>
          </span>
          {%- if subtitle != blank -%}
            <span class="jf-label">{{ subtitle | escape }} - / {{ item_number }}</span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  {%- else -%}
    <div class="jf-pdp-look-grid" aria-hidden="true">
      {%- for i in (1..max_products) -%}
        <div class="jf-pdp-look-card jf-pdp-look-card--skeleton">
          <span class="jf-pdp-look-card__image"></span>
          <span class="jf-pdp-look-card__meta">
            <strong></strong>
            <span></span>
          </span>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</product-recommendations>

{% schema %}
{
  "name": "JF PDP complete look",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Defaults to the current product on product pages."
    },
    {
      "type": "select",
      "id": "recommendation_type",
      "label": "Recommendation type",
      "options": [
        {
          "value": "complementary",
          "label": "Complementary"
        },
        {
          "value": "related",
          "label": "Related"
        }
      ],
      "default": "complementary"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "/ 07 - STYLE WITH"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "COMPLETE THE LOOK."
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "VIEW THE EDIT ->"
    }
  ],
  "presets": [
    {
      "name": "JF PDP complete look"
    }
  ]
}
{% endschema %}
