<section class="jf-categories">
  <div class="jf-section-header">
    <div class="jf-label">{{ section.settings.eyebrow | escape }}</div>
    <h2 class="jf-section-header__title jf-display">{{ section.settings.heading | escape }}</h2>
    {%- if section.settings.link_label != blank -%}
      <a class="jf-section-header__action jf-label" href="{{ section.settings.link | default: routes.all_products_collection_url }}">
        {{ section.settings.link_label | escape }}
      </a>
    {%- endif -%}
  </div>
  <div class="jf-spacer-line" aria-hidden="true"></div>

  <div class="jf-category-grid">
    {%- for block in section.blocks -%}
      {%- liquid
        if block.settings.image != blank
          assign image_url = block.settings.image | image_url: width: 1000
        elsif block.settings.fallback_asset != blank
          assign image_url = block.settings.fallback_asset | asset_url
        else
          assign image_url = ''
        endif
      -%}
      <a class="jf-category-card jf-image-cover" href="{{ block.settings.link | default: routes.all_products_collection_url }}" style="{% if image_url != blank %}--jf-image: url('{{ image_url }}');{% endif %}" {{ block.shopify_attributes }}>
        <div class="jf-category-card__top jf-label">
          <span>{{ block.settings.index | escape }}</span>
          <span>{{ block.settings.count | escape }}</span>
        </div>
        <div class="jf-category-card__bottom">
          <div class="jf-category-card__title jf-display">{{ block.settings.title | escape }}</div>
          <div class="jf-label">{{ block.settings.cta | escape }}</div>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "JF category tiles",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "/ 03 - SHOP BY PURSUIT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BUILT FOR THE ROUND."
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "ALL CATEGORIES ->"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "index",
          "label": "Index",
          "default": "/ 01"
        },
        {
          "type": "text",
          "id": "count",
          "label": "Count",
          "default": "12 PIECES"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "PERFORMANCE"
        },
        {
          "type": "text",
          "id": "cta",
          "label": "CTA",
          "default": "SHOP ->"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "fallback_asset",
          "label": "Fallback asset filename",
          "default": "jf-category-01.jpg"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "JF category tiles",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "index": "/ 01",
            "count": "12 PIECES",
            "title": "PERFORMANCE",
            "fallback_asset": "jf-category-01.jpg"
          }
        },
        {
          "type": "category",
          "settings": {
            "index": "/ 02",
            "count": "18 PIECES",
            "title": "EVERYDAY",
            "fallback_asset": "jf-category-02.jpg"
          }
        },
        {
          "type": "category",
          "settings": {
            "index": "/ 03",
            "count": "9 PIECES",
            "title": "ACCESSORIES",
            "fallback_asset": "jf-category-03.jpg"
          }
        }
      ]
    }
  ]
}
{% endschema %}
